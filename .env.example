# Database
DATABASE_URL=postgresql+asyncpg://arms:arms_dev@localhost:5432/arms_db

# Redis
REDIS_URL=redis://localhost:6379/0

# MinIO (S3-compatible storage)
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=arms-pdfs
MINIO_SECURE=false

# LLM Provider
LLM_PROVIDER=fake
LLM_BASE_URL=
LLM_API_KEY=
LLM_MODEL=

# PDF settings
PDF_MAX_SIZE_MB=50
PDF_DOWNLOAD_TIMEOUT_SECONDS=120
PDF_CONNECT_TIMEOUT_SECONDS=30
PDF_MAX_REDIRECTS=5

# Celery
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# API
API_V1_STR=/api/v1
PROJECT_NAME=ARMS AI Audit System
DEBUG=false

# Processing
MAX_AUDIT_ATTEMPTS=3
PDF_RETRY_MAX_ATTEMPTS=3
PDF_RETRY_BACKOFF_BASE=2.0
OUTBOX_RECONCILE_INTERVAL_SECONDS=30
OUTBOX_STALE_AFTER_SECONDS=120

# Comma-separated test/admin accounts with cross-user read-only scope
ARMS_ADMIN_ACCOUNTS=
